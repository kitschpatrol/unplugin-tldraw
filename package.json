{
	"name": "@kitschpatrol/unplugin-tldraw",
	"version": "1.1.0",
	"description": "Unplugin for module-style import of local tldraw .tldr files with automatic conversion to SVG or PNG.",
	"keywords": [
		"tldraw",
		"tldr",
		"unplugin",
		"vite",
		"webpack",
		"rspack",
		"rollup",
		"rolldown",
		"esbuild",
		"farm",
		"bun",
		"nuxt",
		"diagram",
		"drawing",
		"whiteboard",
		"sketch",
		"import",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/unplugin-tldraw",
	"bugs": "https://github.com/kitschpatrol/unplugin-tldraw/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/unplugin-tldraw.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./*": "./*",
		"./api": "./dist/api.js",
		"./bun": "./dist/bun.js",
		"./client": {
			"types": "./dist/client.d.ts"
		},
		"./esbuild": "./dist/esbuild.js",
		"./farm": "./dist/farm.js",
		"./nuxt": "./dist/nuxt.js",
		"./rolldown": "./dist/rolldown.js",
		"./rollup": "./dist/rollup.js",
		"./rspack": "./dist/rspack.js",
		"./vite": "./dist/vite.js",
		"./webpack": "./dist/webpack.js"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*",
				"./*"
			]
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "tsdown --watch",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"play": "poptab && pnpm -C playground run dev",
		"release": "bumpp --commit 'Release: %s' && pnpm build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm publish",
		"test": "vitest run",
		"test:browser": "vitest run --config vitest.browser.config.ts"
	},
	"dependencies": {
		"@kitschpatrol/tldraw-cli": "^5.0.16",
		"@types/node": "~22.18.13",
		"defu": "^6.1.7",
		"lognow": "^0.6.1",
		"p-limit": "^7.3.0",
		"pretty-bytes": "^7.1.0",
		"pretty-ms": "^9.3.0",
		"unplugin": "^3.0.0"
	},
	"devDependencies": {
		"@farmfe/core": ">=1.7.11",
		"@kitschpatrol/shared-config": "^7.5.2",
		"@nuxt/kit": "^4.4.2",
		"@nuxt/schema": "^4.4.2",
		"@rspack/core": "^2.0.1",
		"@sxzz/test-utils": "^0.5.18",
		"@vitest/browser-playwright": "^4.1.5",
		"bumpp": "^11.0.1",
		"esbuild": "*",
		"playwright": "^1.59.1",
		"poptab": "^1.1.0",
		"rolldown": "^1.0.0-rc.18",
		"rollup": "^4.60.2",
		"shx": "^0.4.0",
		"tsdown": "^0.21.10",
		"typescript": "~5.9.3",
		"vite": "^7.3.2",
		"vitest": "^4.1.5",
		"webpack": "^5.106.2"
	},
	"peerDependencies": {
		"@farmfe/core": ">=1",
		"@nuxt/kit": "^3 || ^4",
		"@nuxt/schema": "^3 || ^4",
		"@rspack/core": "^1 || ^2",
		"esbuild": "*",
		"rolldown": ">=1.0.0-rc.1",
		"rollup": "^3 || ^4",
		"vite": ">=3",
		"webpack": "^4 || ^5"
	},
	"peerDependenciesMeta": {
		"@farmfe/core": {
			"optional": true
		},
		"@nuxt/kit": {
			"optional": true
		},
		"@nuxt/schema": {
			"optional": true
		},
		"@rspack/core": {
			"optional": true
		},
		"esbuild": {
			"optional": true
		},
		"rolldown": {
			"optional": true
		},
		"rollup": {
			"optional": true
		},
		"vite": {
			"optional": true
		},
		"webpack": {
			"optional": true
		}
	},
	"packageManager": "pnpm@10.33.2",
	"engines": {
		"node": ">=22.18.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
